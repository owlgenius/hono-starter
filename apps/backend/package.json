{
  "name": "@hono-starter/backend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --conditions=development watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js"
  },
  "imports": {
    "#src/*": {
      "types": "./src/*.ts",
      "development": "./src/*.ts",
      "default": "./dist/src/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "import": "./dist/src/app.js"
    },
    "./api": {
      "types": "./src/routes.ts",
      "import": "./dist/src/routes.js"
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/structured-logger": "^0.1.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@libsql/client": "^0.17.3",
    "@scalar/hono-api-reference": "^0.11.3",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-beta.22",
    "hono": "^4.12.23",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "drizzle-kit": "^1.0.0-beta.22",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
