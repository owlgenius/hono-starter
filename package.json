{
  "name": "hono-starter",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @hono-starter/backend",
    "dev:frontend": "npm run dev -w @hono-starter/frontend",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "^3.4.0"
  }
}
